{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "CommonJS",
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "./.unused-test-dist",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": [
    "src/types/index.ts",
    "src/utils/**/*.ts",
    "src/i18n/**/*.tsx",
    "tests/**/*.ts"
  ]
}
